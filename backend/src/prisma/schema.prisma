generator client {
  provider      = "prisma-client-js"
  output        = "./generated2"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identity enums ────────────────────────────────────────────────────────

enum UserRole {
  BUYER
  MERCHANT
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  BANNED
  SUSPENDED
}

enum TokenType {
  ACCESS
  REFRESH
}

enum AdminActionType {
  USER_VIEW
  USER_EDIT
  USER_SUSPEND
  USER_BAN
  USER_DELETE
  USER_BULK_ACTION
  ADMIN_ADD
  ADMIN_EDIT
  ADMIN_REMOVE
  SYSTEM_CONFIG_CHANGE
  EXPORT_DATA
  IMPORT_DATA
  SECURITY_ALERT
  SESSION_TERMINATE
  PASSWORD_RESET
  VERIFICATION_OVERRIDE
}

enum AdminSubRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
}

// ─── Identity models ───────────────────────────────────────────────────────

model User {
  id                  String        @id @default(uuid()) @db.Uuid
  phone               String        @unique
  role                UserRole      @default(BUYER)
  status              UserStatus    @default(PENDING)
  phoneVerified       Boolean       @default(false) @map("phone_verified")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  lastLoginAt         DateTime?     @map("last_login_at") @db.Timestamptz
  failedLoginAttempts Int           @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?     @map("locked_until") @db.Timestamptz
  adminSubRole        AdminSubRole? @map("admin_sub_role")

  profile    UserProfile?
  authTokens AuthToken[]

  @@map("users")
}

model UserProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  firstName       String   @default("") @map("first_name")
  lastName        String   @default("") @map("last_name")
  profileImageUrl String?  @map("profile_image_url")
  locationLat     Decimal? @map("location_lat") @db.Decimal(10, 8)
  locationLng     Decimal? @map("location_lng") @db.Decimal(11, 8)
  address         String?
  city            String?
  country         String?
  preferences     Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model AuthToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  tokenType         TokenType @map("token_type")
  tokenHash         String    @map("token_hash")
  deviceFingerprint String?   @map("device_fingerprint")
  ipAddress         String?   @map("ip_address")
  userAgent         String?   @map("user_agent")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz
  lastUsedAt        DateTime? @map("last_used_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_tokens")
}

// ─── Request enums ─────────────────────────────────────────────────────────

enum RequestStatus {
  DRAFT
  ACTIVE
  HAS_BIDS
  COMPLETED
  CANCELLED
  EXPIRED
}

// ─── Request models ────────────────────────────────────────────────────────

model RequestCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?
  parentId    String?   @map("parent_id") @db.Uuid
  iconUrl     String?   @map("icon_url") @db.VarChar(500)
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  parent   RequestCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children RequestCategory[] @relation("CategoryTree")
  requests Request[]
  drafts   RequestDraft[]

  @@map("request_categories")
}

model Request {
  id              String         @id @default(uuid()) @db.Uuid
  buyerId         String         @map("buyer_id") @db.Uuid
  categoryId      String         @map("category_id") @db.Uuid
  title           String         @db.VarChar(255)
  description     String
  budgetMin       Decimal?       @map("budget_min") @db.Decimal(12, 2)
  budgetMax       Decimal?       @map("budget_max") @db.Decimal(12, 2)
  locationLat     Decimal?       @map("location_lat") @db.Decimal(10, 8)
  locationLng     Decimal?       @map("location_lng") @db.Decimal(11, 8)
  locationAddress String?        @map("location_address")
  locationCity    String?        @map("location_city") @db.VarChar(100)
  locationCountry String?        @map("location_country") @db.VarChar(100)
  status          RequestStatus  @default(DRAFT)
  priorityScore   Int            @default(0) @map("priority_score")
  bidCount        Int            @default(0) @map("bid_count")
  viewCount       Int            @default(0) @map("view_count")
  expiresAt       DateTime?      @map("expires_at") @db.Timestamptz
  publishedAt     DateTime?      @map("published_at") @db.Timestamptz
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  category    RequestCategory    @relation(fields: [categoryId], references: [id])
  images      RequestImage[]
  extensions  RequestExtension[]
  searchIndex RequestSearchIndex?

  @@map("requests")
}

model RequestImage {
  id               String   @id @default(uuid()) @db.Uuid
  requestId        String   @map("request_id") @db.Uuid
  imageUrl         String   @map("image_url") @db.VarChar(500)
  thumbnailUrl     String?  @map("thumbnail_url") @db.VarChar(500)
  originalFilename String?  @map("original_filename") @db.VarChar(255)
  fileSize         BigInt   @map("file_size")
  mimeType         String   @map("mime_type") @db.VarChar(100)
  width            Int?
  height           Int?
  sortOrder        Int      @default(0) @map("sort_order")
  isPrimary        Boolean  @default(false) @map("is_primary")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("request_images")
}

model RequestDraft {
  id              String    @id @default(uuid()) @db.Uuid
  buyerId         String    @map("buyer_id") @db.Uuid
  categoryId      String?   @map("category_id") @db.Uuid
  title           String?   @db.VarChar(255)
  description     String?
  budgetMin       Decimal?  @map("budget_min") @db.Decimal(12, 2)
  budgetMax       Decimal?  @map("budget_max") @db.Decimal(12, 2)
  locationLat     Decimal?  @map("location_lat") @db.Decimal(10, 8)
  locationLng     Decimal?  @map("location_lng") @db.Decimal(11, 8)
  locationAddress String?   @map("location_address")
  autoSaveData    Json      @default("{}") @map("auto_save_data")
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  category RequestCategory? @relation(fields: [categoryId], references: [id])

  @@map("request_drafts")
}

model RequestExtension {
  id                String   @id @default(uuid()) @db.Uuid
  requestId         String   @map("request_id") @db.Uuid
  originalExpiresAt DateTime @map("original_expires_at") @db.Timestamptz
  newExpiresAt      DateTime @map("new_expires_at") @db.Timestamptz
  extensionReason   String?  @map("extension_reason")
  extendedBy        String?  @map("extended_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("request_extensions")
}

model RequestSearchIndex {
  id           String    @id @default(uuid()) @db.Uuid
  requestId    String    @unique @map("request_id") @db.Uuid
  searchVector String?   @map("search_vector")
  categoryPath String?   @map("category_path")
  locationText String?   @map("location_text")
  budgetRange  String?   @map("budget_range")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("request_search_index")
}

model SavedSearch {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String   @db.VarChar(255)
  searchCriteria Json     @map("search_criteria")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("saved_searches")
}

// ─── Bidding enums ─────────────────────────────────────────────────────────

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum AmountType {
  FIXED
  PERCENTAGE
  RANGE
}

// ─── Bidding models ────────────────────────────────────────────────────────

model Bid {
  id            String    @id @default(uuid()) @db.Uuid
  requestId     String    @map("request_id") @db.Uuid
  merchantId    String    @map("merchant_id") @db.Uuid
  amount        Decimal   @db.Decimal(12, 2)
  deliveryDays  Int       @map("delivery_days")
  deliveryNotes String?   @map("delivery_notes")
  specialTerms  String?   @map("special_terms")
  status        BidStatus @default(PENDING)
  priorityScore Int       @default(0) @map("priority_score")
  isTemplate    Boolean   @default(false) @map("is_template")
  templateName  String?   @map("template_name") @db.VarChar(100)
  bidFee        Decimal   @default(0.00) @map("bid_fee") @db.Decimal(10, 2)
  feePaid       Boolean   @default(false) @map("fee_paid")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  expiresAt     DateTime? @map("expires_at") @db.Timestamptz
  acceptedAt    DateTime? @map("accepted_at") @db.Timestamptz
  rejectedAt    DateTime? @map("rejected_at") @db.Timestamptz
  withdrawnAt   DateTime? @map("withdrawn_at") @db.Timestamptz

  @@unique([requestId, merchantId])
  @@map("bids")
}

// ─── Chat enums ────────────────────────────────────────────────────────────

enum RoomType {
  DIRECT
  GROUP
  REQUEST
  BID
  SUPPORT
}

enum ParticipantRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

// ─── Chat models (rooms + participants in PostgreSQL) ──────────────────────
// Messages are stored in MongoDB — see src/models/ChatMessage.js

model ChatRoom {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @db.VarChar(255)
  description      String?
  type             RoomType  @default(DIRECT)
  relatedRequestId String?   @map("related_request_id") @db.Uuid
  relatedBidId     String?   @map("related_bid_id") @db.Uuid
  createdBy        String    @map("created_by") @db.Uuid
  isActive         Boolean   @default(true) @map("is_active")
  maxParticipants  Int       @default(100) @map("max_participants")
  lastMessageAt    DateTime? @map("last_message_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  participants ChatParticipant[]

  @@map("chat_rooms")
}

model ChatParticipant {
  id           String          @id @default(uuid()) @db.Uuid
  roomId       String          @map("room_id") @db.Uuid
  userId       String          @map("user_id") @db.Uuid
  role         ParticipantRole @default(MEMBER)
  joinedAt     DateTime        @default(now()) @map("joined_at") @db.Timestamptz
  lastReadAt   DateTime?       @map("last_read_at") @db.Timestamptz
  isMuted      Boolean         @default(false) @map("is_muted")
  isBanned     Boolean         @default(false) @map("is_banned")
  bannedUntil  DateTime?       @map("banned_until") @db.Timestamptz
  bannedBy     String?         @map("banned_by") @db.Uuid
  bannedReason String?         @map("banned_reason")
  leftAt       DateTime?       @map("left_at") @db.Timestamptz

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@map("chat_participants")
}

// ─── Notification enums ────────────────────────────────────────────────────

enum NotificationType {
  SYSTEM
  REQUEST
  BID
  PAYMENT
  CHAT
  SUBSCRIPTION
  SECURITY
  MARKETING
}

enum NotifChannel {
  IN_APP
  PUSH
  EMAIL
  SMS
  WEBHOOK

  @@map("notification_channel")
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  DELIVERED
  FAILED
  EXPIRED
  READ
}

enum NotifDeliveryStatus {
  PENDING
  PROCESSING
  SENT
  DELIVERED
  FAILED
  BOUNCED

  @@map("notif_delivery_status")
}

enum NotifAnalyticsEvent {
  SENT
  DELIVERED
  READ
  FAILED
  BOUNCED
  CLICKED
  DISMISSED

  @@map("notif_analytics_event")
}

// ─── Notification models ───────────────────────────────────────────────────

model NotificationTemplate {
  id              String            @id @default(uuid()) @db.Uuid
  name            String            @db.VarChar(100)
  type            NotificationType
  channel         NotifChannel
  subjectTemplate String?           @map("subject_template") @db.VarChar(500)
  contentTemplate String            @map("content_template")
  variables       Json              @default("{}")
  defaultLocale   String            @default("en") @map("default_locale") @db.VarChar(10)
  isActive        Boolean           @default(true) @map("is_active")
  version         Int               @default(1)
  createdBy       String?           @map("created_by") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  notifications Notification[]

  @@map("notification_templates")
}

model Notification {
  id                String               @id @default(uuid()) @db.Uuid
  userId            String               @map("user_id") @db.Uuid
  type              NotificationType
  title             String               @db.VarChar(255)
  content           String
  channel           NotifChannel         @default(IN_APP)
  priority          NotificationPriority @default(NORMAL)
  status            NotificationStatus   @default(PENDING)
  templateId        String?              @map("template_id") @db.Uuid
  templateVariables Json                 @default("{}") @map("template_variables")
  metadata          Json                 @default("{}")
  scheduledAt       DateTime?            @map("scheduled_at") @db.Timestamptz
  sentAt            DateTime?            @map("sent_at") @db.Timestamptz
  deliveredAt       DateTime?            @map("delivered_at") @db.Timestamptz
  readAt            DateTime?            @map("read_at") @db.Timestamptz
  expiresAt         DateTime?            @map("expires_at") @db.Timestamptz
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  template   NotificationTemplate?  @relation(fields: [templateId], references: [id])
  deliveries NotificationDelivery[]
  reads      NotificationRead[]
  analytics  NotificationStat[]

  @@map("notifications")
}

model NotificationChannel {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  channelType  NotifChannel @map("channel_type")
  isEnabled    Boolean      @default(true) @map("is_enabled")
  deviceToken  String?      @map("device_token") @db.VarChar(500)
  emailAddress String?      @map("email_address") @db.VarChar(255)
  phoneNumber  String?      @map("phone_number") @db.VarChar(20)
  preferences  Json         @default("{}")
  lastUsedAt   DateTime?    @map("last_used_at") @db.Timestamptz
  verifiedAt   DateTime?    @map("verified_at") @db.Timestamptz
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([userId, channelType])
  @@map("notification_channels")
}

model NotificationPreference {
  id                  String                @id @default(uuid()) @db.Uuid
  userId              String                @map("user_id") @db.Uuid
  notificationType    NotificationType      @map("notification_type")
  channelType         NotifChannel          @map("channel_type")
  isEnabled           Boolean               @default(true) @map("is_enabled")
  quietHoursStart     String?               @map("quiet_hours_start")
  quietHoursEnd       String?               @map("quiet_hours_end")
  minPriority         NotificationPriority? @map("min_priority")
  maxFrequencyMinutes Int?                  @map("max_frequency_minutes")
  preferences         Json                  @default("{}")
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([userId, notificationType, channelType])
  @@map("notification_preferences")
}

model NotificationDelivery {
  id             String              @id @default(uuid()) @db.Uuid
  notificationId String              @map("notification_id") @db.Uuid
  channelType    NotifChannel        @map("channel_type")
  provider       String              @db.VarChar(100)
  recipient      String              @db.VarChar(500)
  status         NotifDeliveryStatus @default(PENDING)
  attemptCount   Int                 @default(0) @map("attempt_count")
  sentAt         DateTime?           @map("sent_at") @db.Timestamptz
  deliveredAt    DateTime?           @map("delivered_at") @db.Timestamptz
  errorMessage   String?             @map("error_message")
  errorCode      String?             @map("error_code") @db.VarChar(100)
  metadata       Json                @default("{}")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@map("notification_deliveries")
}

model NotificationRead {
  id                String   @id @default(uuid()) @db.Uuid
  notificationId    String   @map("notification_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  readAt            DateTime @default(now()) @map("read_at") @db.Timestamptz
  deviceFingerprint String?  @map("device_fingerprint") @db.VarChar(255)
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@map("notification_reads")
}

model NotificationStat {
  id             String              @id @default(uuid()) @db.Uuid
  notificationId String?             @map("notification_id") @db.Uuid
  userId         String?             @map("user_id") @db.Uuid
  eventType      NotifAnalyticsEvent @map("event_type")
  channelType    NotifChannel        @map("channel_type")
  provider       String?             @db.VarChar(100)
  deliveryTimeMs Int?                @map("delivery_time_ms")
  success        Boolean
  errorCode      String?             @map("error_code") @db.VarChar(100)
  metadata       Json                @default("{}")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz

  notification Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)

  @@map("notification_analytics")
}

// ─── Bidding models ────────────────────────────────────────────────────────

model BidTemplate {
  id                String     @id @default(uuid()) @db.Uuid
  merchantId        String     @map("merchant_id") @db.Uuid
  name              String     @db.VarChar(100)
  description       String?
  amountType        AmountType @default(FIXED) @map("amount_type")
  amountPercentage  Decimal?   @map("amount_percentage") @db.Decimal(5, 2)
  fixedAmount       Decimal?   @map("fixed_amount") @db.Decimal(12, 2)
  deliveryDays      Int?       @map("delivery_days")
  deliveryNotes     String?    @map("delivery_notes")
  specialTerms      String?    @map("special_terms")
  isActive          Boolean    @default(true) @map("is_active")
  usageCount        Int        @default(0) @map("usage_count")
  successCount      Int        @default(0) @map("success_count")
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  @@map("bid_templates")
}

