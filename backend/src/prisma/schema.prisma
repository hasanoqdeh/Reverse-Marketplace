generator client {
  provider      = "prisma-client-js"
  output        = "./generated2"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identity enums ────────────────────────────────────────────────────────

enum UserRole {
  BUYER
  MERCHANT
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  BANNED
  SUSPENDED
}

enum TokenType {
  ACCESS
  REFRESH
}

enum AdminActionType {
  USER_VIEW
  USER_EDIT
  USER_SUSPEND
  USER_BAN
  USER_DELETE
  USER_BULK_ACTION
  ADMIN_ADD
  ADMIN_EDIT
  ADMIN_REMOVE
  SYSTEM_CONFIG_CHANGE
  EXPORT_DATA
  IMPORT_DATA
  SECURITY_ALERT
  SESSION_TERMINATE
  PASSWORD_RESET
  VERIFICATION_OVERRIDE
}

enum AdminSubRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
}

// ─── Identity models ───────────────────────────────────────────────────────

model User {
  id                  String        @id @default(uuid()) @db.Uuid
  phone               String        @unique
  role                UserRole      @default(BUYER)
  status              UserStatus    @default(PENDING)
  phoneVerified       Boolean       @default(false) @map("phone_verified")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  lastLoginAt         DateTime?     @map("last_login_at") @db.Timestamptz
  failedLoginAttempts Int           @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?     @map("locked_until") @db.Timestamptz
  adminSubRole        AdminSubRole? @map("admin_sub_role")

  profile    UserProfile?
  authTokens AuthToken[]

  @@map("users")
}

model UserProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  firstName       String   @default("") @map("first_name")
  lastName        String   @default("") @map("last_name")
  profileImageUrl String?  @map("profile_image_url")
  locationLat     Decimal? @map("location_lat") @db.Decimal(10, 8)
  locationLng     Decimal? @map("location_lng") @db.Decimal(11, 8)
  address         String?
  city            String?
  country         String?
  preferences     Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model AuthToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  tokenType         TokenType @map("token_type")
  tokenHash         String    @map("token_hash")
  deviceFingerprint String?   @map("device_fingerprint")
  ipAddress         String?   @map("ip_address")
  userAgent         String?   @map("user_agent")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz
  lastUsedAt        DateTime? @map("last_used_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_tokens")
}

// ─── Request enums ─────────────────────────────────────────────────────────

enum RequestStatus {
  DRAFT
  ACTIVE
  HAS_BIDS
  COMPLETED
  CANCELLED
  EXPIRED
}

// ─── Request models ────────────────────────────────────────────────────────

model RequestCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?
  parentId    String?   @map("parent_id") @db.Uuid
  iconUrl     String?   @map("icon_url") @db.VarChar(500)
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  parent   RequestCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children RequestCategory[] @relation("CategoryTree")
  requests Request[]
  @@map("request_categories")
}

model Request {
  id              String         @id @default(uuid()) @db.Uuid
  buyerId         String         @map("buyer_id") @db.Uuid
  categoryId      String?        @map("category_id") @db.Uuid
  title           String         @db.VarChar(255)
  description     String
  budgetMin       Decimal?       @map("budget_min") @db.Decimal(12, 2)
  budgetMax       Decimal?       @map("budget_max") @db.Decimal(12, 2)
  locationLat     Decimal?       @map("location_lat") @db.Decimal(10, 8)
  locationLng     Decimal?       @map("location_lng") @db.Decimal(11, 8)
  locationAddress String?        @map("location_address")
  locationCity    String?        @map("location_city") @db.VarChar(100)
  locationCountry String?        @map("location_country") @db.VarChar(100)
  status          RequestStatus  @default(DRAFT)
  priorityScore   Int            @default(0) @map("priority_score")
  bidCount        Int            @default(0) @map("bid_count")
  viewCount       Int            @default(0) @map("view_count")
  expiresAt       DateTime?      @map("expires_at") @db.Timestamptz
  publishedAt     DateTime?      @map("published_at") @db.Timestamptz
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  category RequestCategory? @relation(fields: [categoryId], references: [id])
  images   RequestImage[]

  @@map("requests")
}

model RequestImage {
  id               String   @id @default(uuid()) @db.Uuid
  requestId        String   @map("request_id") @db.Uuid
  imageUrl         String   @map("image_url") @db.VarChar(500)
  thumbnailUrl     String?  @map("thumbnail_url") @db.VarChar(500)
  originalFilename String?  @map("original_filename") @db.VarChar(255)
  fileSize         BigInt   @map("file_size")
  mimeType         String   @map("mime_type") @db.VarChar(100)
  width            Int?
  height           Int?
  sortOrder        Int      @default(0) @map("sort_order")
  isPrimary        Boolean  @default(false) @map("is_primary")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("request_images")
}

model SavedSearch {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String   @db.VarChar(255)
  searchCriteria Json     @map("search_criteria")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("saved_searches")
}

// ─── Bidding enums ─────────────────────────────────────────────────────────

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum FulfillmentStatus {
  AWAITING
  PREPARING
  IN_DELIVERY
  DELIVERED
  CONFIRMED
}

enum ReviewType {
  BUYER_TO_MERCHANT
  MERCHANT_TO_BUYER
}

// ─── Bidding models ────────────────────────────────────────────────────────

model Bid {
  id            String    @id @default(uuid()) @db.Uuid
  requestId     String    @map("request_id") @db.Uuid
  merchantId    String    @map("merchant_id") @db.Uuid
  amount        Decimal   @db.Decimal(12, 2)
  deliveryDays  Int       @map("delivery_days")
  deliveryNotes String?   @map("delivery_notes")
  specialTerms  String?   @map("special_terms")
  status        BidStatus @default(PENDING)
  priorityScore Int       @default(0) @map("priority_score")
  isTemplate    Boolean   @default(false) @map("is_template")
  templateName  String?   @map("template_name") @db.VarChar(100)
  bidFee        Decimal   @default(0.00) @map("bid_fee") @db.Decimal(10, 2)
  feePaid       Boolean   @default(false) @map("fee_paid")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  expiresAt     DateTime? @map("expires_at") @db.Timestamptz
  acceptedAt          DateTime?         @map("accepted_at") @db.Timestamptz
  rejectedAt          DateTime?         @map("rejected_at") @db.Timestamptz
  withdrawnAt         DateTime?         @map("withdrawn_at") @db.Timestamptz
  chatRoomId          String?           @map("chat_room_id") @db.Uuid
  fulfillmentStatus   FulfillmentStatus? @map("fulfillment_status")
  fulfillmentUpdatedAt DateTime?         @map("fulfillment_updated_at") @db.Timestamptz

  reviews Review[]

  @@unique([requestId, merchantId])
  @@map("bids")
}

// ─── Chat enums ────────────────────────────────────────────────────────────

enum RoomType {
  DIRECT
  GROUP
  REQUEST
  BID
  SUPPORT
}

// ─── Chat models ──────────────────────────────────────────────────────────
// Messages are stored in MongoDB — see src/models/ChatMessage.js

model ChatRoom {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @db.VarChar(255)
  description      String?
  type             RoomType  @default(DIRECT)
  relatedRequestId String?   @map("related_request_id") @db.Uuid
  relatedBidId     String?   @map("related_bid_id") @db.Uuid
  createdBy        String    @map("created_by") @db.Uuid
  isActive         Boolean   @default(true) @map("is_active")
  maxParticipants  Int       @default(100) @map("max_participants")
  lastMessageAt    DateTime? @map("last_message_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("chat_rooms")
}

// ─── Notification enums ────────────────────────────────────────────────────

enum NotificationType {
  NEW_MESSAGE
  BID_PLACED
  STATUS_IN_DELIVERY
  BID_ACCEPTED
  BUYER_REVIEW

  @@map("notification_type")
}

// ─── Notification model ────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(255)
  body      String
  data      Json             @default("{}")
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@index([isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

// ─── Bidding models ────────────────────────────────────────────────────────

// ─── Review models ─────────────────────────────────────────────────────────

model Review {
  id         String     @id @default(uuid()) @db.Uuid
  bidId      String     @map("bid_id") @db.Uuid
  requestId  String     @map("request_id") @db.Uuid
  reviewerId String     @map("reviewer_id") @db.Uuid
  revieweeId String     @map("reviewee_id") @db.Uuid
  type       ReviewType
  rating     Int
  comment    String?
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz

  bid Bid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@unique([bidId, reviewerId])
  @@index([revieweeId])
  @@map("reviews")
}


