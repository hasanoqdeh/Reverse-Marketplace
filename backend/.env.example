# =============================================================================
# BACKEND — ENVIRONMENT TEMPLATE
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

NODE_ENV=development                # development | production | test
LOG_LEVEL=info                      # error | warn | info | debug
GATEWAY_PORT=3000

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reverse_marketplace
DB_USER=postgres
DB_PASSWORD=your_db_password

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/reverse_marketplace

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                     # Leave empty if no auth
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=root
RABBITMQ_PASSWORD=your_rabbitmq_password
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://root:your_rabbitmq_password@localhost:5672

# -----------------------------------------------------------------------------
# JWT — generate with: openssl rand -base64 64
# -----------------------------------------------------------------------------
JWT_SECRET=generate_a_strong_secret_minimum_64_characters
JWT_REFRESH_SECRET=generate_a_different_strong_secret_minimum_64_characters
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# -----------------------------------------------------------------------------
# SMS
# -----------------------------------------------------------------------------
SMS_PROVIDER=console                # console (dev) | twilio (prod)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# OTP
# -----------------------------------------------------------------------------
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
MAX_CONCURRENT_SESSIONS=5
ADMIN_SESSION_TIMEOUT_HOURS=8
DEVICE_FINGERPRINT_ENABLED=true
DEVICE_FINGERPRINT_SALT=generate_a_random_salt_string

# -----------------------------------------------------------------------------
# Rate limiting (requests per window per user/IP)
# -----------------------------------------------------------------------------
RATE_LIMIT_PHONE_LOGIN=5
RATE_LIMIT_OTP_VERIFY=10
RATE_LIMIT_OTP_RESEND=3
RATE_LIMIT_TOKEN_REFRESH=20
RATE_LIMIT_ADMIN_ACCESS=10

# -----------------------------------------------------------------------------
# CORS — comma-separated allowed origins
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# -----------------------------------------------------------------------------
# Uploads
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=10
MAX_IMAGES_PER_REQUEST=10
UPLOAD_DIR=uploads

# -----------------------------------------------------------------------------
# Request lifecycle
# -----------------------------------------------------------------------------
DEFAULT_REQUEST_EXPIRY_HOURS=72
MAX_EXTENSION_HOURS=48

# -----------------------------------------------------------------------------
# Cleanup jobs
# -----------------------------------------------------------------------------
CLEANUP_INTERVAL_MINUTES=60
AUDIT_LOG_RETENTION_DAYS=90
