# ========================================
# REVERSE MARKETPLACE - ENVIRONMENT TEMPLATE
# ========================================
# Copy this file to .env.dev for development or .env.prod for production
# Update the values below according to your environment

# ========================================
# GLOBAL CONFIGURATION
# ========================================
NODE_ENV=development
LOG_LEVEL=info

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Primary Database (Shared)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reverse_marketplace_dev
DB_USER=postgres
DB_PASSWORD=password

# Auth Service Database (DATABASE_* for auth service compatibility)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=reverse_marketplace_auth
DATABASE_USER=auth_service_user
DATABASE_PASSWORD=secure_auth_password_change_in_production
DATABASE_URL=postgresql://auth_service_user:secure_auth_password_change_in_production@localhost:5432/reverse_marketplace_auth

# ========================================
# REDIS CONFIGURATION
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ========================================
# RABBITMQ CONFIGURATION
# ========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=password
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://localhost:5672

# ========================================
# JWT AUTHENTICATION
# ========================================
JWT_SECRET=your_super_secure_jwt_secret_key_minimum_64_characters
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_key_minimum_64_characters
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ========================================
# SERVICE PORTS
# ========================================
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
PRODUCT_SERVICE_PORT=3003
ORDER_SERVICE_PORT=3004
PAYMENT_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
CHAT_SERVICE_PORT=3007
BIDDING_SERVICE_PORT=3008
SUBSCRIPTION_SERVICE_PORT=3009

# ========================================
# EXTERNAL PORTS (Docker Host Ports)
# ========================================
DB_PORT_EXTERNAL=5432
DB_PORT=5432
REDIS_PORT_EXTERNAL=6379
REDIS_PORT=6379
RABBITMQ_PORT_EXTERNAL=5672
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT_EXTERNAL=15672
RABBITMQ_MGMT_PORT=15672
BACKEND_PORT_EXTERNAL=3000
BACKEND_PORT=3000
ADMIN_PORT_EXTERNAL=3001
ADMIN_PORT=3000

# ========================================
# DOCKER CONFIGURATION
# ========================================
DOCKER_NETWORK=reverse-marketplace-dev

# DOCKER SERVICE HOSTNAMES
DB_HOST_DOCKER=postgres
DATABASE_HOST_DOCKER=postgres
REDIS_HOST_DOCKER=redis
RABBITMQ_HOST_DOCKER=rabbitmq

# DOCKER API URLS
NEXT_PUBLIC_API_URL_DOCKER=http://backend:3000/api/v1
NEXT_PUBLIC_WS_URL_DOCKER=ws://backend:3000

# ========================================
# API ENDPOINTS
# ========================================
API_BASE_URL=http://localhost:3000/api/v1
WS_URL=ws://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ========================================
# SECURITY CONFIGURATION
# ========================================
# Rate Limiting
RATE_LIMIT_PHONE_LOGIN=5
RATE_LIMIT_OTP_VERIFY=10
RATE_LIMIT_OTP_RESEND=3
RATE_LIMIT_TOKEN_REFRESH=20
RATE_LIMIT_ADMIN_ACCESS=10

# Security Settings
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
MAX_CONCURRENT_SESSIONS=5
ADMIN_SESSION_TIMEOUT_HOURS=8

# Device Fingerprinting
DEVICE_FINGERPRINT_ENABLED=true
DEVICE_FINGERPRINT_SALT=secure_device_fingerprint_salt_change_in_production

# ========================================
# SMS SERVICE CONFIGURATION (TWILIO)
# ========================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ========================================
# OTP CONFIGURATION
# ========================================
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# ========================================
# CORS CONFIGURATION
# ========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ========================================
# MONITORING & METRICS
# ========================================
ENABLE_METRICS=true
METRICS_PORT=9090

# ========================================
# SESSION CLEANUP
# ========================================
CLEANUP_INTERVAL_MINUTES=60
AUDIT_LOG_RETENTION_DAYS=90

# ========================================
# EXTERNAL SERVICES
# ========================================
# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Firebase
FIREBASE_CONFIG=your_firebase_configuration_json

# Stripe Payment
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# ========================================
# DEVELOPMENT SETTINGS
# ========================================
DEV_MODE=true
