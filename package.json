{
  "name": "reverse-marketplace",
  "version": "1.0.0",
  "description": "Reverse Marketplace - Real-time bidding platform connecting buyers to merchants",
  "private": true,
  "scripts": {
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "dev": "nx run-many --target=serve --all --parallel",
    "docker:dev": "docker compose -f infrastructure/docker/docker-compose.dev.yml up --build",
    "docker:prod": "docker compose -f infrastructure/docker/docker-compose.prod.yml up --build",
    "k8s:deploy": "kubectl apply -f infrastructure/k8s/",
    "migrate": "nx run-many --target=migrate --all",
    "seed": "cd scripts && npx ts-node seed.ts",
    "seed:cleanup": "cd scripts && npx ts-node seed.ts --cleanup",
    "seed:identity": "cd scripts && npx ts-node seed.ts --identity-only",
    "seed:request": "cd scripts && npx ts-node seed.ts --request-only",
    "seed:matching": "cd scripts && npx ts-node seed.ts --matching-only",
    "seed:bidding": "cd scripts && npx ts-node seed.ts --bidding-only",
    "seed:chat": "cd scripts && npx ts-node seed.ts --chat-only",
    "seed:payment": "cd scripts && npx ts-node seed.ts --payment-only",
    "seed:docker": "node scripts/seed-simple.js",
    "seed:docker:cleanup": "node scripts/seed-simple.js --cleanup",
    "seed:docker:identity": "node scripts/seed-simple.js --identity-only",
    "seed:docker:request": "node scripts/seed-simple.js --request-only",
    "seed:docker:matching": "node scripts/seed-simple.js --matching-only",
    "seed:docker:bidding": "node scripts/seed-simple.js --bidding-only",
    "seed:docker:chat": "node scripts/seed-simple.js --chat-only",
    "seed:docker:payment": "node scripts/seed-simple.js --payment-only",
    "seed:docker:databases": "node scripts/seed-simple.js --databases-only",
    "seed:docker:stop": "node scripts/seed-simple.js --stop"
  },
  "devDependencies": {
    "@nx/workspace": "^17.0.0",
    "@nx/js": "^17.0.0",
    "@nx/nest": "^17.0.0",
    "@nx/next": "^17.0.0",
    "typescript": "^5.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "nx": "22.7.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}