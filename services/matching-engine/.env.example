# Database
DATABASE_URL="postgresql://admin:password@localhost:5432/reverse_marketplace_matching?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# RabbitMQ
RABBITMQ_HOST="localhost"
RABBITMQ_PORT=5672
RABBITMQ_USERNAME="admin"
RABBITMQ_PASSWORD="password"
RABBITMQ_EXCHANGE="reverse_marketplace"

# Service
PORT=3002
NODE_ENV="development"

# Matching Configuration
MIN_TRUST_SCORE=3.5
MAX_MERCHANTS_PER_REQUEST=50
MATCH_TIMEOUT_MS=500
GEO_RADIUS_KM=50
MERCHANT_COOLDOWN_MINUTES=5

# Performance
REDIS_LOOKUP_TIMEOUT_MS=50
CONCURRENT_MATCHES=1000
BATCH_SIZE=100

# Monitoring
PROMETHEUS_ENABLED=true
METRICS_PORT=9090

# Logging
LOG_LEVEL="info"
CORRELATION_ID_ENABLED=true
