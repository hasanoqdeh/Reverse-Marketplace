# MongoDB
MONGODB_URI="mongodb://admin:password@localhost:27017/reverse_marketplace_bidding?authSource=admin"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# RabbitMQ
RABBITMQ_HOST="localhost"
RABBITMQ_PORT=5672
RABBITMQ_USERNAME="admin"
RABBITMQ_PASSWORD="password"
RABBITMQ_EXCHANGE="reverse_marketplace"

# Service
PORT=3003
NODE_ENV="development"

# Bidding Configuration
BID_EXPIRY_HOURS=24
MAX_BID_IMAGES=5
MAX_BID_NOTES_LENGTH=1000
MIN_BID_PRICE=0.01
MAX_BID_PRICE=100000

# Currency Configuration
DEFAULT_CURRENCY="OMR"
SUPPORTED_CURRENCIES="OMR,USD,EUR"

# Rate Limiting
BID_SUBMISSION_RATE_LIMIT=10
BID_VIEW_RATE_LIMIT=100

# Performance
MONGODB_CONNECTION_POOL_SIZE=10
REDIS_LOOKUP_TIMEOUT_MS=50
CONCURRENT_BID_PROCESSING=1000

# Monitoring
PROMETHEUS_ENABLED=true
METRICS_PORT=9091

# Logging
LOG_LEVEL="info"
CORRELATION_ID_ENABLED=true

# Security
JWT_SECRET="your-super-secret-jwt-key"
API_KEY_HEADER="x-api-key"
