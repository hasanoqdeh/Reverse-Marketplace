# Cassandra
CASSANDRA_CONTACT_POINTS="localhost:9042"
CASSANDRA_LOCAL_DATACENTER="datacenter1"
CASSANDRA_KEYSPACE="reverse_marketplace_chat"
CASSANDRA_USERNAME=""
CASSANDRA_PASSWORD=""
CASSANDRA_REPLICATION_FACTOR=3

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# RabbitMQ
RABBITMQ_HOST="localhost"
RABBITMQ_PORT=5672
RABBITMQ_USERNAME="admin"
RABBITMQ_PASSWORD="password"
RABBITMQ_EXCHANGE="reverse_marketplace"

# Service
PORT=3005
NODE_ENV="development"

# Socket.io
SOCKET_CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# Media Storage
STORAGE_TYPE="s3"
S3_BUCKET="reverse-marketplace-chat"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,video/mp4,audio/mpeg"

# Chat Configuration
MAX_MESSAGE_LENGTH=1000
MESSAGE_RETENTION_DAYS=365
TYPING_TIMEOUT_SECONDS=5
CONVERSATION_ARCHIVE_DAYS=30

# Rate Limiting
MESSAGE_RATE_LIMIT=30
UPLOAD_RATE_LIMIT=5

# Performance
CASSANDRA_CONSISTENCY_LEVEL="QUORUM"
CASSANDRA_REQUEST_TIMEOUT=5000
REDIS_LOOKUP_TIMEOUT_MS=50
CONCURRENT_SOCKET_CONNECTIONS=100000

# Monitoring
PROMETHEUS_ENABLED=true
METRICS_PORT=9093

# Logging
LOG_LEVEL="info"
CORRELATION_ID_ENABLED=true

# Security
JWT_SECRET="your-super-secret-jwt-key"
API_KEY_HEADER="x-api-key"
