# Database
DATABASE_URL="postgresql://admin:password@localhost:5432/reverse_marketplace_identity?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-key-change-in-production"
REFRESH_TOKEN_EXPIRES_IN="7d"

# RabbitMQ
RABBITMQ_HOST="localhost"
RABBITMQ_PORT=5672
RABBITMQ_USERNAME="admin"
RABBITMQ_PASSWORD="password"
RABBITMQ_EXCHANGE="reverse_marketplace"

# Service
PORT=3000
NODE_ENV="development"

# OTP
OTP_TTL=300
OTP_LENGTH=6

# SMS Provider (for future implementation)
SMS_PROVIDER="twilio"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
