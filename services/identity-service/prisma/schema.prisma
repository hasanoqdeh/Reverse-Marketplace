// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  MERCHANT
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  COMMERCIAL_REGISTRATION
  IDENTITY_DOCUMENT
  TAX_CERTIFICATE
  TRADE_LICENSE
}

model User {
  id           String    @id @default(uuid())
  phoneNumber  String    @unique
  fullName     String?
  role         UserRole  @default(BUYER)
  isVerified   Boolean   @default(false)
  isBanned     Boolean   @default(false)
  trustScore   Float     @default(0.0)
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  refreshTokens           RefreshToken[]
  merchantProfile         MerchantProfile?
  notificationPreferences NotificationPreferences?

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model MerchantProfile {
  id                    String              @id @default(uuid())
  userId                String              @unique
  businessName          String
  commercialRegistration String?
  verificationStatus    VerificationStatus  @default(PENDING)
  coverageAreas         Json?
  categories            Json?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  // Relations
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents  MerchantDocument[]

  @@map("merchant_profiles")
}

model MerchantDocument {
  id           String        @id @default(uuid())
  merchantId   String
  documentType DocumentType
  documentUrl  String
  uploadedAt   DateTime      @default(now())

  // Relations
  merchant MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("merchant_documents")
}

model NotificationPreferences {
  id                String   @id @default(uuid())
  userId            String   @unique
  pushEnabled       Boolean  @default(true)
  smsEnabled        Boolean  @default(true)
  marketingEnabled  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}
