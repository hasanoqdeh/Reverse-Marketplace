# Database
DATABASE_URL="postgresql://admin:password@localhost:5432/reverse_marketplace_requests?schema=public"

# RabbitMQ
RABBITMQ_HOST="localhost"
RABBITMQ_PORT=5672
RABBITMQ_USERNAME="admin"
RABBITMQ_PASSWORD="password"
RABBITMQ_EXCHANGE="reverse_marketplace"

# AWS S3
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="reverse-marketplace-uploads"
AWS_S3_BUCKET_URL="https://reverse-marketplace-uploads.s3.amazonaws.com"

# Service
PORT=3001
NODE_ENV="development"

# Request Configuration
MAX_IMAGES_PER_REQUEST=10
MAX_IMAGE_SIZE_MB=10
REQUEST_EXPIRY_HOURS=72
IMAGE_QUALITY=80

# CDN
CDN_BASE_URL="https://cdn.reverse-marketplace.com"

# Moderation
PROFANITY_FILTER_ENABLED=true
SPAM_DETECTION_ENABLED=true
