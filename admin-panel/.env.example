# Admin Panel Environment Configuration

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000

# Authentication Configuration
NEXT_PUBLIC_SESSION_TIMEOUT=28800000  # 8 hours in milliseconds
NEXT_PUBLIC_TOKEN_REFRESH_INTERVAL=900000  # 15 minutes in milliseconds

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_AUDIT_LOGS=true
NEXT_PUBLIC_ENABLE_BULK_OPERATIONS=true
NEXT_PUBLIC_ENABLE_EXPORT=true

# Development Settings
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_LOG_LEVEL=info

# Security Settings
NEXT_PUBLIC_REQUIRE_DEVICE_FINGERPRINT=true
NEXT_PUBLIC_MAX_LOGIN_ATTEMPTS=5
NEXT_PUBLIC_OTP_LENGTH=6

# UI Configuration
NEXT_PUBLIC_THEME=default
NEXT_PUBLIC_LANGUAGE=en
NEXT_PUBLIC_TIMEZONE=UTC

# Monitoring
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true
